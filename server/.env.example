# ─── LLM-to-API Bridge — Environment Configuration ───────────────────
# Copy this file to .env and fill in your values.

# API key for the calibration LLM (required for /calibrate endpoint)
LLM_API_KEY=sk-your-api-key-here

# Base URL for the OpenAI-compatible API
LLM_BASE_URL=https://api.openai.com/v1

# Model to use for calibration
LLM_MODEL=gpt-4o-mini

# Timeout (in seconds) for chat requests waiting on the extension
REQUEST_TIMEOUT=120

# Server bind address
HOST=0.0.0.0
PORT=8000
